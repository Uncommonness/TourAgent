# Windows desktop ini files
Desktop.ini

# macOS folder metadata
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \r
Icon
\r

# macOS Finder 정보
__MACOSX/

# ───────────────────────────────────────────────────────────
# 2. 개발도구(IDE) & 에디터
# ───────────────────────────────────────────────────────────
# VSCode
.vscode/

# JetBrains (IntelliJ, PyCharm, WebStorm 등)
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# ───────────────────────────────────────────────────────────
